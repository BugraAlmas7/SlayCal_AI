from IPython.core.display import skip_doctest
import torch
from PIL import Image

model.gradient_checkpointing_disable()
model.eval()
processor.tokenizer.clean_up_tokenization_spaces=False

test_image_path = "jpg document way"
image=Image.open(test_image_path).convert("RGB")

prompt="<|begin_of_text|><|start_header_id|>user<|end_header_id|>\n\n<|image|>Can you give me the JSON macros for this meal?<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n\n"
inputs= processor(
    images=image,
    text=prompt,
    add_special_tokens=False,
    return_tensors="pt"
).to(model.device)
print("thinking")
outputs=model.generate(
    **inputs,
    max_new_tokens=150,
    temperature=0.1,
    do_sample=True,
    use_cache=True,
    pad_token_id=processor.tokenizer.eos_token_id
)
generated_text=processor.decode(outputs[0], skip_special_tokens=True)
answer = generated_text.split("assistant\n\n")[-1].strip()
print("output:\n")
print(answer)
